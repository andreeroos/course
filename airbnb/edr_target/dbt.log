{"data": {"msg": "Elementary: --ELEMENTARY-MACRO-OUTPUT-START--[{\"unique_id\": \"model.airbnb.dim_listings_hosts\", \"invocation_id\": \"c19faa8f-2940-4ce2-9b3e-2f3612d6fbdf\", \"name\": \"dim_listings_hosts\", \"schema\": \"DEV\", \"status\": \"skipped\", \"execution_time\": 0, \"full_refresh\": false, \"materialization\": \"table\", \"compiled_code\": null, \"generated_at\": \"2026-03-09 16:06:44\"}, {\"unique_id\": \"model.airbnb.fct_reviews\", \"invocation_id\": \"c19faa8f-2940-4ce2-9b3e-2f3612d6fbdf\", \"name\": \"fct_reviews\", \"schema\": \"DEV\", \"status\": \"success\", \"execution_time\": 2.7, \"full_refresh\": false, \"materialization\": \"incremental\", \"compiled_code\": \"\\nwith  __dbt__cte__src_reviews as (\\nwith raw_reviews as (\\nselect * \\nfrom AIRBNB.raw.raw_reviews\\n\\n)\\nSELECT\\n    LISTING_ID, \\n    DATE as REVIEW_DATE, \\n    REVIEWER_NAME, \\n    COMMENTS AS REVIEW_TEXT, \\n    SENTIMENT AS REVIEW_SENTIMENT\\nFROM\\n    raw_reviews\\n), src_reviews as (\\n\\nselect * from __dbt__cte__src_reviews\\n)\\nselect * from src_reviews\\nwhere review_text is not null\\n\\nAND review_date> (select max(review_date) from AIRBNB.DEV.fct_reviews)\\n\\n\", \"generated_at\": \"2026-03-09 16:06:44\"}, {\"unique_id\": \"model.airbnb.dim_listings_cleansed\", \"invocation_id\": \"c19faa8f-2940-4ce2-9b3e-2f3612d6fbdf\", \"name\": \"dim_listings_cleansed\", \"schema\": \"DEV\", \"status\": \"success\", \"execution_time\": 0.7, \"full_refresh\": false, \"materialization\": \"view\", \"compiled_code\": \"\\nwith  __dbt__cte__src_listings as (\\nwith raw_listings as (\\nselect * \\nfrom AIRBNB.raw.raw_listings\\n\\n)\\nSELECT\\n    id AS listing_id,\\n    name AS listing_name,\\n    listing_url,\\n    room_type,\\n    minimum_nights,\\n    host_id,\\n    price AS price_str,\\n    created_at,\\n    updated_at\\nFROM\\n    raw_listings\\n), src_listings as(\\nselect * from __dbt__cte__src_listings\\n\\n)\\nSELECT\\n  listing_id,\\n  listing_name,\\n  room_type,\\n  CASE\\n    WHEN minimum_nights = 0 THEN 1\\n    ELSE minimum_nights\\n  END AS minimum_nights,\\n  host_id,\\n  REPLACE(price_str,'$') :: NUMBER(10,2) AS price,\\n  created_at,\\n  updated_at\\nFROM\\n  src_listings\", \"generated_at\": \"2026-03-09 16:06:44\"}, {\"unique_id\": \"model.airbnb.mart_fullmoon_reviews\", \"invocation_id\": \"c19faa8f-2940-4ce2-9b3e-2f3612d6fbdf\", \"name\": \"mart_fullmoon_reviews\", \"schema\": \"DEV\", \"status\": \"success\", \"execution_time\": 2.8, \"full_refresh\": false, \"materialization\": \"table\", \"compiled_code\": \"\\n\\nWITH fct_reviews AS (\\n    SELECT * FROM AIRBNB.DEV.fct_reviews\\n),\\nfull_moon_dates AS (\\n    SELECT * FROM AIRBNB.DEV.seed_full_moon_dates\\n)\\n\\nSELECT\\n  r.*,\\n  CASE\\n    WHEN fm.full_moon_date IS NULL THEN 'not full moon'\\n    ELSE 'full moon'\\n  END AS is_full_moon\\nFROM\\n  fct_reviews\\n  r\\n  LEFT JOIN full_moon_dates\\n  fm\\n  ON (TO_DATE(r.review_date) = DATEADD(DAY, 1, fm.full_moon_date))\", \"generated_at\": \"2026-03-09 16:06:44\"}, {\"unique_id\": \"model.airbnb.dim_hosts_cleansed\", \"invocation_id\": \"c19faa8f-2940-4ce2-9b3e-2f3612d6fbdf\", \"name\": \"dim_hosts_cleansed\", \"schema\": \"DEV\", \"status\": \"error\", \"execution_time\": 0, \"full_refresh\": false, \"materialization\": \"view\", \"compiled_code\": \"\\nwith  __dbt__cte__src_hosts as (\\nwith raw_hosts as (\\nselect * \\nfrom AIRBNB.raw.raw_hosts\\n)\\nSELECT\\n    ID as host_id, \\n    NAME as host_name, \\n    IS_SUPERHOST, \\n    CREATED_AT, \\n    UPDATED_AT\\nFROM\\n    raw_hosts\\n), src_hosts as(\\nselect * from __dbt__cte__src_hosts\\n\\n)\\nSELECT+\\n  HOST_ID, \\n  NVL(HOST_NAME, 'Anonymous') AS HOST_NAME, \\n  IS_SUPERHOST, \\n  CREATED_AT, \\n  UPDATED_AT\\nFROM\\n  src_hosts\", \"generated_at\": \"2026-03-09 16:06:44\"}]--ELEMENTARY-MACRO-OUTPUT-END--"}, "info": {"category": "", "code": "I062", "extra": {}, "invocation_id": "72e24a49-7051-4295-b421-9ac54cfdf8fc", "level": "info", "msg": "El