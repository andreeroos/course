n                  schema_name,\n                  depends_on_macros,\n                  depends_on_nodes,\n                  original_path as full_path,\n                  path,\n                  patch_path,\n                  generated_at,\n                  unique_key,\n                  incremental_strategy\n                from AIRBNB.DEV.dbt_snapshots\n              )\n            select * from dbt_artifacts_snapshots\n    /* --ELEMENTARY-METADATA-- {\"command\": \"run-operation\", \"elementary_component\": \"OSS\", \"invocation_id\": \"6db1748d-1027-416a-b916-de1ce5f17b08\", \"package_name\": \"elementary\", \"resource_name\": \"log_macro_results\", \"resource_type\": \"macro\"} --END-ELEMENTARY-METADATA-- */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"elementary\", \"target_name\": \"dev\", \"connection_name\": \"macro_log_macro_results\"} */", "name": "SQLQuery", "pid": 61108, "thread": "MainThread", "ts": "2026-03-09T16:26:27.230328Z"}}
